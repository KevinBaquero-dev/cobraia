generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ────────────────────────────────────────────

enum Plan {
  BASIC
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  TRIAL
  CANCELLED
  PAST_DUE
}

enum UserRole {
  OWNER
  ADMIN
  VIEWER
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  CANCELLED
  OVERDUE
}

enum FiscalType {
  COBRO
  ELECTRONICA
}

// ─── TENANTS ──────────────────────────────────────────

model Tenant {
  id                 String             @id @default(uuid())
  name               String
  slug               String             @unique
  email              String             @unique
  companyName        String             @map("company_name")
  companySlogan      String?            @map("company_slogan")
  logoUrl            String?            @map("logo_url")
  brandColor         String?            @map("brand_color")
  templateId         Int?               @map("template_id")
  plan               Plan               @default(BASIC)
  subscriptionStatus SubscriptionStatus @default(TRIAL) @map("subscription_status")
  wompiCustomerId    String?            @map("wompi_customer_id")
  invoiceCurrency    String             @default("COP") @map("invoice_currency")
  invoicePaymentDays Int                @default(30) @map("invoice_payment_days")
  whatsappNumber     String?            @map("whatsapp_number")
  taxId              String?            @map("tax_id")
  phone              String?            @map("phone")
  address            String?            @map("address")
  invoiceNotes       String?            @map("invoice_notes")
  isActive           Boolean            @default(true) @map("is_active")
  settings           Json               @default("{}")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  users         User[]
  clients       Client[]
  invoices      Invoice[]
  subscriptions Subscription[]
  sequence      TenantSequence?
  systemTemplate     SystemTemplate?    @relation(fields: [templateId], references: [id])
  auditLogs     AuditLog[]
  chatSessions  ChatConversation[]

  @@map("tenants")
}

// ─── USERS ────────────────────────────────────────────

model User {
  id                String    @id @default(uuid())
  tenantId          String    @map("tenant_id")
  email             String
  passwordHash      String?   @map("password_hash")
  name              String
  phone             String?   @map("phone")
  role              UserRole  @default(VIEWER)
  isActive          Boolean   @default(true) @map("is_active")
  googleId          String?   @map("google_id")
  lastLoginAt       DateTime? @map("last_login_at")
  failedLoginCount  Int       @default(0) @map("failed_login_count")
  lockedUntil       DateTime? @map("locked_until")
  twoFactorEnabled  Boolean   @default(false) @map("two_factor_enabled")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  tenant           Tenant             @relation(fields: [tenantId], references: [id])
  invoicesCreated  Invoice[]          @relation("InvoiceCreatedBy")
  revisions        InvoiceRevision[]
  auditLogs        AuditLog[]
  chatConversations ChatConversation[]

  @@unique([tenantId, email])
  @@map("users")
}

// ─── CLIENTS ──────────────────────────────────────────

model Client {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  name      String
  email     String?
  phone     String?
  taxId     String?  @map("tax_id")
  address   Json     @default("{}")
  notes     String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  invoices Invoice[]

  @@map("clients")
}

// ─── INVOICES ─────────────────────────────────────────

model Invoice {
  id             String        @id @default(uuid())
  tenantId       String        @map("tenant_id")
  clientId       String        @map("client_id")
  createdById    String        @map("created_by_id")
  invoiceNumber  String        @map("invoice_number")
  isNumberManual Boolean       @default(false) @map("is_number_manual")
  status         InvoiceStatus @default(DRAFT)
  issueDate      DateTime      @map("issue_date")
  dueDate        DateTime      @map("due_date")
  paidAt         DateTime?     @map("paid_at")
  subtotal       Decimal       @db.Decimal(12, 2)
  taxRate        Decimal       @default(0) @db.Decimal(5, 2) @map("tax_rate")
  taxAmount      Decimal       @default(0) @db.Decimal(12, 2) @map("tax_amount")
  retentionRate  Decimal       @default(0) @db.Decimal(5, 2) @map("retention_rate")
  retentionAmount Decimal      @default(0) @db.Decimal(12, 2) @map("retention_amount")
  discount       Decimal       @default(0) @db.Decimal(12, 2)
  total          Decimal       @db.Decimal(12, 2)
  currency       String        @default("COP")
  notes          String?
  pdfUrl         String?       @map("pdf_url")
  xlsxUrl        String?       @map("xlsx_url")
  version        Int           @default(1)
  editedAt       DateTime?     @map("edited_at")

  // Campos DIAN reservados para futura integración
  fiscalType     FiscalType    @default(COBRO) @map("fiscal_type")
  cufe           String?
  dianResponse   Json?         @map("dian_response")
  qrCodeUrl      String?       @map("qr_code_url")

  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  tenant    Tenant            @relation(fields: [tenantId], references: [id])
  client    Client            @relation(fields: [clientId], references: [id])
  createdBy User              @relation("InvoiceCreatedBy", fields: [createdById], references: [id])
  items     InvoiceItem[]
  revisions InvoiceRevision[]
  payments  Payment[]

  @@unique([tenantId, invoiceNumber])
  @@map("invoices")
}

// ─── INVOICE ITEMS ────────────────────────────────────

model InvoiceItem {
  id          String  @id @default(uuid())
  invoiceId   String  @map("invoice_id")
  description String
  quantity    Decimal @db.Decimal(10, 3)
  unitPrice   Decimal @db.Decimal(12, 2) @map("unit_price")
  amount      Decimal @db.Decimal(12, 2)
  sortOrder   Int     @default(0) @map("sort_order")

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_items")
}

// ─── INVOICE REVISIONS ────────────────────────────────

model InvoiceRevision {
  id          String   @id @default(uuid())
  invoiceId   String   @map("invoice_id")
  changedById String   @map("changed_by_id")
  fieldName   String   @map("field_name")
  oldValue    String?  @map("old_value")
  newValue    String?  @map("new_value")
  reason      String?
  changedAt   DateTime @default(now()) @map("changed_at")

  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  changedBy User    @relation(fields: [changedById], references: [id])

  @@map("invoice_revisions")
}

// ─── PAYMENTS ─────────────────────────────────────────

model Payment {
  id          String   @id @default(uuid())
  invoiceId   String   @map("invoice_id")
  amount      Decimal  @db.Decimal(12, 2)
  paidAt      DateTime @map("paid_at")
  method      String?
  reference   String?
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("payments")
}

// ─── SYSTEM TEMPLATES ─────────────────────────────────

model SystemTemplate {
  id           Int     @id @default(autoincrement())
  name         String
  description  String?
  type         String  // 'invoice' | 'statement'
  pairedWith   Int?    @map("paired_with")
  thumbnailUrl String? @map("thumbnail_url")
  isActive     Boolean @default(true) @map("is_active")
  sortOrder    Int     @default(0) @map("sort_order")
  tenants            Tenant[]

  @@map("system_templates")
}

// ─── TENANT SEQUENCE ──────────────────────────────────

model TenantSequence {
  id         String @id @default(uuid())
  tenantId   String @unique @map("tenant_id")
  lastNumber Int    @default(0) @map("last_number")
  prefix     String @default("")
  padding    Int    @default(6)

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("tenant_sequences")
}

// ─── SUBSCRIPTIONS ────────────────────────────────────

model Subscription {
  id               String             @id @default(uuid())
  tenantId         String             @map("tenant_id")
  plan             Plan
  status           SubscriptionStatus
  wompiReference   String?            @map("wompi_reference")
  currentPeriodStart DateTime         @map("current_period_start")
  currentPeriodEnd   DateTime         @map("current_period_end")
  cancelledAt      DateTime?          @map("cancelled_at")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("subscriptions")
}

// ─── CHAT CONVERSATIONS ───────────────────────────────

model ChatConversation {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  userId    String   @map("user_id")
  channel   String   @default("web")
  messages  Json     @default("[]")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@map("chat_conversations")
}

// ─── AUDIT LOGS ───────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  userId     String?  @map("user_id")
  action     String
  entity     String
  entityId   String?  @map("entity_id")
  metadata   Json     @default("{}")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User?  @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}